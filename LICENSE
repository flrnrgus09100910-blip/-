    <main class="container">
        <div class="card">
            <div class="tabs" id="tabButtons">
                <button class="tab-btn active" data-tab="tab1">📁 포털DB</button>
                <button class="tab-btn" data-tab="tab2">🛒 오픈마켓DB</button>
                <button class="tab-btn" data-tab="tab3">📋 인허가DB</button>
                <button class="tab-btn" data-tab="tab4">🏢 기업DB</button>
            </div>

            <!-- 포털DB 탭 -->
            <div id="tab1" class="tab-content active">
                <div class="badge-total">📌 국내 포털 기준 등록업체 · 총 <span id="portalTotal">0</span>건</div>
                <div class="search-bar">
                    <input type="text" id="searchPortal" class="search-input" placeholder="업체명 또는 업종 검색 (예: 학원, 치킨)">
                    <select id="categoryPortal" class="filter-select">
                        <option value="">전체 업종</option>
                        <option value="교육">교육/학원</option>
                        <option value="음식">음식/외식</option>
                        <option value="의료">의료/병원</option>
                        <option value="미용">미용/네일</option>
                    </select>
                    <button class="btn" id="searchPortalBtn">검색</button>
                </div>
                <div class="table-wrapper">
                    <table id="portalTable">
                        <thead>
                            <tr><th>분류일</th><th>구분</th><th>업체명</th><th>일반전화</th><th>주소</th></tr>
                        </thead>
                        <tbody id="portalTbody"><tr><td colspan="5">로딩 중...</td></tr></tbody>
