    <script>
        // ---------- Mock 데이터 (실제로는 서버에서 받아와야 함) ----------
        const portalMock = [
            { date: "4분전", type: "콘택트렌즈전문", name: "윙크렌즈천호점", phone: "0507-****-9124", addr: "서울 강동구" },
            { date: "6분전", type: "법률사무소", name: "법률사무소이룬", phone: "0507-****-4017", addr: "경기 수원시" },
            { date: "7분전", type: "한식", name: "급한마음탕평화광장점", phone: "0507-****-5802", addr: "전남 목포시" },
            { date: "16분전", type: "카페", name: "고냉이자점", phone: "0507-****-6929", addr: "문화의길" },
            { date: "27분전", type: "영어교육", name: "넥스트학원", phone: "050-****-5825", addr: "다정중앙로" },
            { date: "1시간전", type: "필라테스", name: "스포츠필라테스", phone: "0507-****-7400", addr: "경기 안산시" },
        ];
        const openMock = [
            { name: "전자랜드 공식몰", platform: "쿠팡", category: "가전", phone: "02-****-1111" },
            { name: "데일리룩스", platform: "G마켓", category: "패션", phone: "070-****-2233" },
        ];
        const licenseMock = [
            { name: "가야원", type: "식품제조가공업", addr: "전남 해남군", regDate: "2026-02-10" },
            { name: "하늘약국", type: "약국", addr: "서울 마포구", regDate: "2026-01-05" },
            { name: "취화선악홀", type: "유흥주점영업", addr: "전북 김제시", regDate: "2008-05-12" },
        ];
        const corpMock = [
            { name: "한국디지털솔루션", ceo: "김대표", emp: "52명", sector: "SW개발" },
            { name: "삼영제조", ceo: "이영희", emp: "128명", sector: "자동차부품" }
        ];

        let portalData = [...portalMock];
        let licenseData = [...licenseMock];

        // 통계 업데이트
        function updateStats() {
            document.getElementById("totalDB").innerText = "7,908,633";
            document.getElementById("newToday").innerText = "333";
            document.getElementById("pending").innerText = "1,403";
            document.getElementById("portalTotal").innerText = portalMock.length;
            document.getElementById("openTotal").innerText = openMock.length;
            document.getElementById("licenseTotal").innerText = licenseMock.length;
            document.getElementById("corpTotal").innerText = corpMock.length;
        }

        function renderPortalTable(data) {
            const tbody = document.getElementById("portalTbody");
            if(!data.length) { tbody.innerHTML = '<tr><td colspan="5">검색 결과가 없습니다.</td></tr>'; return; }
            tbody.innerHTML = data.map(item => `
                <tr>
                    <td>${item.date}</td><td>${item.type}</td><td>${item.name}</td><td>${item.phone}</td><td>${item.addr}</td>
                </tr>
            `).join("");
        }

        function renderOpenTable() {
            const tbody = document.getElementById("openTbody");
            tbody.innerHTML = openMock.map(item => `<tr><td>${item.name}</td><td>${item.platform}</td><td>${item.category}</td><td>${item.phone}</td></tr>`).join("");
        }
        function renderLicenseTable(data) {
            const tbody = document.getElementById("licenseTbody");
            if(!data.length) { tbody.innerHTML = '<tr><td colspan="4">검색 결과 없음</td></tr>'; return; }
            tbody.innerHTML = data.map(item => `<tr><td>${item.name}</td><td>${item.type}</td><td>${item.addr}</td><td>${item.regDate}</td></tr>`).join("");
        }
        function renderCorpTable() {
            const tbody = document.getElementById("corpTbody");
            tbody.innerHTML = corpMock.map(item => `<tr><td>${item.name}</td><td>${item.ceo}</td><td>${item.emp}</td><td>${item.sector}</td></tr>`).join("");
        }

        // 포털 검색 필터
        function filterPortal() {
            const keyword = document.getElementById("searchPortal").value.trim().toLowerCase();
            const categoryVal = document.getElementById("categoryPortal").value;
            let filtered = portalMock.filter(item => {
                const matchName = item.name.toLowerCase().includes(keyword) || item.type.toLowerCase().includes(keyword);
                const matchCat = categoryVal === "" ? true : (item.type.includes(categoryVal) || (categoryVal==="교육" && item.type.includes("교육")) || (categoryVal==="음식" && item.type.includes("식")));
                return matchName && matchCat;
            });
            renderPortalTable(filtered);
        }
        function filterLicense() {
            const kw = document.getElementById("searchLicense").value.trim().toLowerCase();
            const filtered = licenseMock.filter(item => item.name.toLowerCase().includes(kw) || item.type.toLowerCase().includes(kw));
            renderLicenseTable(filtered);
        }

        // 탭 전환
        function initTabs() {
            const btns = document.querySelectorAll(".tab-btn");
            const contents = document.querySelectorAll(".tab-content");
            btns.forEach(btn => {
                btn.addEventListener("click", () => {
                    const tabId = btn.getAttribute("data-tab");
                    btns.forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");
                    contents.forEach(c => c.classList.remove("active"));
                    document.getElementById(tabId).classList.add("active");
                    // 탭 전환시 각 테이블 다시 그리기 (초기화)
                    if(tabId === "tab1") filterPortal();
                    if(tabId === "tab2") renderOpenTable();
                    if(tabId === "tab3") renderLicenseTable(licenseData);
                    if(tabId === "tab4") renderCorpTable();
                });
            });
        }

        document.getElementById("searchPortalBtn").addEventListener("click", filterPortal);
        document.getElementById("searchLicenseBtn").addEventListener("click", filterLicense);
        document.getElementById("searchPortal").addEventListener("keyup", (e) => { if(e.key === "Enter") filterPortal(); });
        document.getElementById("searchLicense").addEventListener("keyup", (e) => { if(e.key === "Enter") filterLicense(); });

        function init() {
            updateStats();
            renderPortalTable(portalData);
            renderOpenTable();
            renderLicenseTable(licenseData);
            renderCorpTable();
            initTabs();
        }
        init();
    </script>
</body>
</html>
